    "@storybook/addon-backgrounds": "7.0.22",
    "@storybook/addon-controls": "^7.0.22",
    "@storybook/addon-docs": "^7.0.22",
    "@storybook/addon-viewport": "^7.0.22",
    "@storybook/addons": "^7.0.22",
    "@storybook/react": "^7.0.22",
    "@storybook/react-webpack5": "^7.0.22",
    "@storybook/source-loader": "^7.0.22",
    "@svgr/cli": "^8.0.1",
    "@svgr/core": "^8.0.0",
    "@testing-library/dom": "^9.3.1",
    "@testing-library/jest-dom": "^5.15.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/lodash": "4.14.186",
    "@types/node": "^20.3.1",
    "@types/react-table": "^7.7.14",
    "@types/to-px": "^1.1.2",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "auto": "^10.37.4",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.5.0",
    "babel-loader": "^9.1.2",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "babel-plugin-typescript-to-proptypes": "^2.1.0",
    "component-test-utils-react": "^1.0.1-beta.2",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^8.43.0",
    "eslint-plugin-jest": "^27.2.2",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-react": "^7.14.3",
    "eslint-plugin-react-hooks": "^4.2.0",
    "file-loader": "^6.2.0",
    "identity-obj-proxy": "^3.0.0",
